/*
 * Cancer-agnostic CNA classifier Nextflow pipeline
 * Input: SAMURAI-derived CNA codification tables, especially cna_events.tsv.
 *
 * GISTIC2 is INCLUDED as a built-in process:
 *   - RUN_GISTIC uses envs/gistic2.yml when conda is enabled.
 *   - --gistic_refgene auto can auto-download the hg38 refgene into the work dir.
 *   - Missing/failed GISTIC continues by default unless --gistic_required true.
 */

params {
  // Input can be a cna_events.tsv file, a single-sample folder, or a cohort folder.
  // --input is the preferred alias; --cna_input and --cna_events are kept for compatibility.
  input             = null
  cna_input         = null
  cna_events        = null
  cna_notation      = null
  pathology         = null      // optional CSV/TSV/XLS/XLSX with pathology diagnosis/IHC; if supplied, token-based pathology agreement is scored
  pathology_sample_col = null    // optional override for sample ID column, e.g. illumina_sample_id
  pathology_case_col = null      // optional override for case/accession column
  pathology_diagnosis_col = null // optional override for final diagnosis column

  // Optional biomedical transformer model scoring for pathology agreement.
  // It is attempted only when --pathology is provided and samples are matched.
  // The pipeline remains fully functional if transformers/torch/models are unavailable;
  // failures are reported in 07_pathology/pathology_model_trials.tsv.
  pathology_use_biomed_models = true
  pathology_biomed_models = 'microsoft/BiomedNLP-BiomedBERT-base-uncased-abstract,dmis-lab/biobert-base-cased-v1.1,emilyalsentzer/Bio_ClinicalBERT'
  pathology_biomed_local_files_only = false
  pathology_biomed_max_tokens = 256
  score_calibration_table = null      // optional validation table with score+binary label for true probability calibration
  score_calibration_score_col = null  // optional score column in calibration table
  score_calibration_label_col = null  // optional binary label column in calibration table
  sample            = null      // backward-compatible alias for --samples
  samples           = null      // optional comma/semicolon/space-separated sample IDs to process
  sample_set        = 'broad_cancer' // cancer/sample-set context: broad_cancer, lymphoma, breast, pancreas, colorectal, leukemia, brain_cns, lung, prostate, ovarian, gastric, sarcoma, etc.
  region_catalog    = null      // optional override; default is assets/pancancer_cna_regions.tsv
  outdir            = 'cna_classifier_results'

  // Genome/chromosome-size support for full neutral-gap GISTIC SEG.
  genome            = 'hg38'
  chrom_sizes       = null
  gistic_window_bp  = 100000

  // Input filtering. Tune these for low-pass WGS depth and your SAMURAI thresholds.
  min_bins          = 3
  min_size_mb       = 0.5
  min_abs_log2      = 0.25
  include_sex       = false
  focal_mb          = 30
  broad_mb          = 30

  // Rule-based CNA burden classes.
  low_events        = 10
  high_events       = 50
  ultra_events      = 100
  high_chromosomes  = 8
  high_altered_mb   = 500
  ultra_altered_mb  = 1000

  // Unsupervised clustering and plots.
  nmf_clusters      = 3
  top_regions       = 80
  plot_top_features = 60

  // Knowledge enrichment and report-style PDFs.
  // The pipeline uses a built-in pan-cancer CNA knowledge dictionary plus optional
  // public Europe PMC / PubMed-indexed metadata queries and optional local Hugging
  // Face literature synthesis/ranking. Internet/model failures are non-fatal by default.
  knowledge_web          = true
  knowledge_allow_fail   = true
  knowledge_max_papers   = 20
  knowledge_timeout      = 20
  knowledge_sleep        = 0.25
  knowledge_user_agent   = 'OncoTracerAI-CNA-knowledge-enrichment/1.0'
  knowledge_lymphoma_terms = 'lymphoma OR DLBCL OR "diffuse large B-cell lymphoma" OR "large B-cell lymphoma" OR "B-cell lymphoma"' // retained for compatibility
  knowledge_cancer_terms = 'cancer OR tumor OR tumour OR carcinoma OR leukemia OR leukaemia OR lymphoma OR sarcoma OR glioma OR "copy number alteration" OR CNA'

  // Optional Hugging Face biomedical NER over retrieved literature abstracts.
  // Disabled by default to keep the conda environment light and reproducible.
  // To use it, install transformers/torch in the environment and run with
  // --knowledge_hf_ner true.
  knowledge_hf_ner       = false
  knowledge_hf_model     = 'd4data/biomedical-ner-all'

  // Optional LLM-style literature synthesis over PubMed/Europe-PMC abstract text.
  // When enabled, the knowledge step tries up to three local Hugging Face text2text/summarization models.
  // If the models are unavailable or fail, the pipeline writes the failed trials and falls back to a deterministic PubMed-text synthesis.
  knowledge_literature_llm = true
  knowledge_literature_llm_models = 'google/flan-t5-small,google/flan-t5-base,Falconsai/medical_summarization'
  knowledge_literature_llm_local_files_only = false
  knowledge_literature_llm_max_features = 24
  knowledge_literature_llm_max_input_chars = 2800
  knowledge_literature_llm_max_new_tokens = 96

  // Deep literature enrichment: for CNA features actually detected in each sample,
  // retrieve larger PubMed/Europe-PMC candidate sets, rank by citation/relevance,
  // and optionally ask local Hugging Face models to select the most influential papers.
  knowledge_deep_literature = true
  knowledge_deep_max_papers_per_feature = 50
  knowledge_deep_top_papers_per_sample = 12
  knowledge_deep_enable_llm_ranker = true
  knowledge_deep_llm_ranker_models = 'google/flan-t5-small,google/flan-t5-base,Falconsai/medical_summarization'
  knowledge_deep_llm_ranker_local_files_only = false
  knowledge_deep_llm_ranker_max_candidates_per_sample = 18
  knowledge_literature_reference_llm_selection = true
  knowledge_literature_top_references = 8

  run_pdf_reports        = true
  run_clinician_reports  = true
  clinician_max_drivers  = 14
  pdf_include_full_events = true
  pdf_max_events         = 0      // 0 means HTML and PDF reports include all CNA events; set e.g. 80 for shorter PDFs

  // GISTIC2: default stage is ON and included through envs/gistic2.yml under -profile conda.
  // Default safe mode continues if GISTIC/refgene cannot be resolved.
  // Use --gistic_required true for a strict run.
  run_gistic        = true
  gistic_required   = false
  gistic_min_samples = 2        // skip GISTIC2 in single-sample mode unless deliberately lowered

  // Use 'auto' to use gistic2 from the conda environment/PATH, or provide an absolute path.
  gistic_exe        = 'auto'

  // Use 'auto' to download hg38 refgene into the work directory, or provide an absolute path.
  gistic_refgene    = 'auto'
  gistic_auto_download_refgene = true

  // Optional CNV exclusion file. Leave empty unless you have a curated hg38 germline CNV list.
  gistic_cnv_file   = null

  // GISTIC input and parameters.
  gistic_seg_type   = 'full'      // full = gistic_full.seg with neutral gaps; events = altered events only
  gistic_use_markers = true
  gistic_broad      = true
  gistic_conf       = 0.90
  gistic_qvt        = 0.25
  gistic_ta         = 0.10
  gistic_td         = 0.10
  gistic_cap        = 1.5
  gistic_rx         = 0          // 0 keeps sex chromosomes if --include_sex was used; 1 removes X/Y
  gistic_brlen      = 0.70
  gistic_join_segment_size = 4   // GISTIC -js, not CPU count
  gistic_maxseg     = 2500
  gistic_scent      = 'median'
  gistic_smallmem   = 1
  gistic_savegene   = 1
  gistic_armpeel    = 1
  gistic_smalldisk  = 0
  gistic_verbose    = 20
  gistic_cpus       = 4          // Nextflow resource request only; GISTIC -js is independent
  gistic_memory     = '12 GB'
  gistic_time       = '8h'
}

process {
  executor = 'local'
  cpus = 4
  memory = '8 GB'
  time = '4h'
  errorStrategy = 'terminate'
}

conda.enabled = true

profiles {
  conda {
    conda.enabled = true
  }

  // Uses conda for Python stages but expects --gistic_exe to point to a pre-installed local GISTIC2.
  // Useful if the HCC conda package is problematic on your server.
  local_gistic {
    conda.enabled = true
    withName: RUN_GISTIC {
      conda = null
    }
  }

  docker {
    docker.enabled = true
    process.container = 'continuumio/miniconda3:24.5.0-0'
  }

  singularity {
    singularity.enabled = true
    singularity.autoMounts = true
    process.container = 'docker://continuumio/miniconda3:24.5.0-0'
  }
}
