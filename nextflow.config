params {
  mode = null
  outdir = null
  lpwgs_root = '/media/server/STORAGE/LPWGS_2025'

  run_cna_classifier = false
  docker = false
  singularity = false
  conda = false
  cna_classifier_sample_set = 'broad_cancer'
  pathology_csv = null
  pathology_sample_col = 'illumina_sample_id'
  pathology_case_col = 'case_code'
  pathology_diagnosis_col = 'final_diagnosis'
  pathology_use_biomed_models = true
  pathology_biomed_local_files_only = false
  force = false
  refine_skip_install = false

  // Container execution. Docker is the preferred portable runtime; Conda is
  // kept as the native fallback; Singularity/Apptainer can pull the Docker image.
  docker_image = 'carlosfarkas/oncotracer:latest'
  singularity_image = 'docker://carlosfarkas/oncotracer:latest'
  docker_user = '1000:1000'
  // Clear the image ENTRYPOINT when Nextflow itself launches process containers.
  docker_container_options = '--entrypoint ""'
  cna_classifier_profile = 'conda'

  // ONT SAMURAI inputs
  ont_folder = null
  ont_barcodes = null
  ont_sample_names = null
  ont_samurai_outdir = null
  ont_analysis_type = 'liquid_biopsy'
  ont_caller = 'ichorcna'
  ont_binsize_kb = 500
  ont_ref = null
  ont_normal_folder = null
  ont_normal_barcodes = null
  ont_normal_sample_names = null
  ont_build_pon = false
  ont_min_age_minutes = 0
  ont_force_realign = false

  // Illumina FASTQ inputs
  illumina_samplesheet = null
  illumina_samurai_outdir = null
  illumina_analysis_type = 'solid_biopsy'
  illumina_caller = 'qdnaseq'
  illumina_binsize_kb = 100

  // Refinement defaults matching current manual runs.
  fine_bin_kb_ont = 25
  fine_bin_kb_illumina = 10
  search_radius_bins = 2
  min_mapq = 20
  min_local_log2_diff_ont = 0.12
  min_local_log2_diff_illumina = 0.10
  min_adjacent_seg_delta = 0.10
  min_bic_gain = 6
  permutations = 300
  permutation_p = 0.05
  accept_rule = 'p_and_bic'
  max_ci_fraction_of_coarse = 1.0
  zipcnv_mode = 'adapted'
  zipcnv_window_bins = 5
  zipcnv_k = 0.05
  zipcnv_min_segment_bins = 3
  zipcnv_min_abs_log2 = 0.25
  zipcnv_compare_min_overlap = 0.50
}


process.executor = 'local'
process.errorStrategy = 'terminate'
process.maxRetries = 0

conda.enabled = params.conda
conda.useMamba = false

docker.enabled = params.docker
docker.runOptions = "-u ${params.docker_user} -e HOME=/tmp -e MPLCONFIGDIR=/tmp/matplotlib -e XDG_CACHE_HOME=/tmp/cache -v ${params.lpwgs_root}:${params.lpwgs_root}"

singularity.enabled = params.singularity
singularity.autoMounts = true
singularity.runOptions = "--bind ${params.lpwgs_root}:${params.lpwgs_root}"

process.container = params.singularity ? params.singularity_image : (params.docker ? params.docker_image : null)
process.containerOptions = params.docker ? params.docker_container_options : null

profiles {
  local {
    process.executor = 'local'
    process.errorStrategy = 'terminate'
    process.maxRetries = 0
  }

  conda {
    process.executor = 'local'
    process.errorStrategy = 'terminate'
    process.maxRetries = 0
    conda.enabled = true
    conda.useMamba = false
  }

  docker {
    process.executor = 'local'
    process.errorStrategy = 'terminate'
    process.maxRetries = 0
    docker.enabled = true
    docker.runOptions = "-u ${params.docker_user} -e HOME=/tmp -e MPLCONFIGDIR=/tmp/matplotlib -e XDG_CACHE_HOME=/tmp/cache -v ${params.lpwgs_root}:${params.lpwgs_root}"
    process.container = params.docker_image
    process.containerOptions = params.docker_container_options
  }

  singularity {
    process.executor = 'local'
    process.errorStrategy = 'terminate'
    process.maxRetries = 0
    singularity.enabled = true
    singularity.autoMounts = true
    singularity.runOptions = "--bind ${params.lpwgs_root}:${params.lpwgs_root}"
    process.container = params.singularity_image
  }
}
